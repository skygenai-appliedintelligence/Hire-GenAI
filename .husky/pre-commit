#!/usr/bin/env bash
. "$(dirname -- "$0")/_/husky.sh"

# Get staged file list
changed=$(git diff --cached --name-only)

# Ask helper to build regex of allowed paths for the current user (owned modules)
owned_paths_regex=$(node tools/hook-helpers.js ownedPathsRegex) || exit 1

if [ -z "$changed" ]; then
  exit 0
fi

# If any changed file does NOT match allowed paths, block the commit
if echo "$changed" | grep -Ev "$owned_paths_regex" >/dev/null; then
  echo "❌ Commit blocked: you modified files outside your owned modules."
  echo "   Take a lock:  pnpm run featurectl -- checkout <module>"
  echo "   Or revert those changes."
  echo "   Allowed (owned) path regex: $owned_paths_regex"
  exit 1
fi

exit 0